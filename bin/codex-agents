#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
SOURCE_AGENTS_DIR="${REPO_ROOT}/agents"
SOURCE_SKILLS_DIR="${REPO_ROOT}/skills"
TARGET_CODEX_DIR="${HOME}/.codex"
TARGET_AGENTS_DIR=""
TARGET_SKILLS_DIR=""
TARGET_AGENTS_RULES_FILE=""
ENTRYPOINT_BEGIN="<!-- BEGIN CODEX-AGENTS MANAGED ENTRYPOINT -->"
ENTRYPOINT_END="<!-- END CODEX-AGENTS MANAGED ENTRYPOINT -->"
JSON_OUTPUT=0
REMAINING_ARGS=()
LINK_BIN_DIR="${HOME}/.local/bin"

usage() {
  cat <<'EOF'
Usage:
  codex-agents install [--target PATH]   Copy bundled agents and skills into PATH (default: ~/.codex)
  codex-agents update [--target PATH]    Overwrite installed agents and skills from the current repo
  codex-agents status [--target PATH] [--json]    Show a lightweight installed-state summary
  codex-agents doctor [--target PATH] [--json]    Check installed agents, skills, and managed entrypoint state
  codex-agents uninstall [--target PATH] Remove bundled agents, orchestrator-routing skill, and the managed entrypoint block
  codex-agents link [--bin-dir PATH]     Symlink this repo's CLI into PATH (default: ~/.local/bin)
  codex-agents unlink [--bin-dir PATH]   Remove the symlink created by `link`
  codex-agents list                      List bundled agent files and skills
  codex-agents version                   Print the current bundled version identifier
EOF
}

set_target_paths() {
  TARGET_AGENTS_DIR="${TARGET_CODEX_DIR}/agents"
  TARGET_SKILLS_DIR="${TARGET_CODEX_DIR}/skills"
  TARGET_AGENTS_RULES_FILE="${TARGET_CODEX_DIR}/AGENTS.md"
}

parse_target_flag() {
  REMAINING_ARGS=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --target)
        [[ $# -ge 2 ]] || {
          echo "Missing value for --target" >&2
          exit 1
        }
        TARGET_CODEX_DIR="$2"
        shift 2
        ;;
      --json)
        JSON_OUTPUT=1
        shift
        ;;
      --bin-dir)
        [[ $# -ge 2 ]] || {
          echo "Missing value for --bin-dir" >&2
          exit 1
        }
        LINK_BIN_DIR="$2"
        shift 2
        ;;
      *)
        REMAINING_ARGS+=("$1")
        shift
        ;;
    esac
  done

  set_target_paths
}

list_agents() {
  find "${SOURCE_AGENTS_DIR}" -maxdepth 1 -type f -name '*.md' -print \
    | xargs -I{} basename "{}" \
    | sort
}

list_skills() {
  find "${SOURCE_SKILLS_DIR}" -mindepth 1 -maxdepth 1 -type d -print \
    | xargs -I{} basename "{}" \
    | sort
}

list_bundle() {
  echo "Bundled agents:"
  list_agents
  echo
  echo "Bundled skills:"
  list_skills
}

check_path_exists() {
  local label="$1"
  local path="$2"

  if [[ -e "${path}" ]]; then
    if (( JSON_OUTPUT == 0 )); then
      printf "OK    %s: %s\n" "${label}" "${path}"
    fi
    return 0
  fi

  if (( JSON_OUTPUT == 0 )); then
    printf "FAIL  %s: missing %s\n" "${label}" "${path}"
  fi
  return 1
}

check_managed_entrypoint() {
  if [[ ! -f "${TARGET_AGENTS_RULES_FILE}" ]]; then
    if (( JSON_OUTPUT == 0 )); then
      printf "FAIL  managed entrypoint: missing %s\n" "${TARGET_AGENTS_RULES_FILE}"
    fi
    return 1
  fi

  local contents
  contents="$(cat "${TARGET_AGENTS_RULES_FILE}")"

  if [[ "${contents}" == *"${ENTRYPOINT_BEGIN}"* && "${contents}" == *"${ENTRYPOINT_END}"* ]]; then
    if [[ "${contents}" == *"orchestrator-routing"* ]]; then
      if (( JSON_OUTPUT == 0 )); then
        printf "OK    managed entrypoint: orchestrator-routing block present\n"
      fi
      return 0
    fi

    if (( JSON_OUTPUT == 0 )); then
      printf "WARN  managed entrypoint: managed block present but missing orchestrator-routing language\n"
    fi
    return 0
  fi

  if (( JSON_OUTPUT == 0 )); then
    printf "FAIL  managed entrypoint: managed block missing from %s\n" "${TARGET_AGENTS_RULES_FILE}"
  fi
  return 1
}

doctor() {
  local failures=0
  local warnings=0
  local installed_agents=0
  local installed_skills=0
  local agents_dir_present=false
  local skills_dir_present=false
  local orchestrator_agent_present=false
  local orchestrator_skill_present=false
  local managed_entrypoint_present=false
  local findings=()
  local next_actions=()

  [[ -d "${TARGET_AGENTS_DIR}" ]] && agents_dir_present=true
  [[ -d "${TARGET_SKILLS_DIR}" ]] && skills_dir_present=true
  [[ -f "${TARGET_AGENTS_DIR}/orchestrator.md" ]] && orchestrator_agent_present=true
  [[ -f "${TARGET_SKILLS_DIR}/orchestrator-routing/SKILL.md" ]] && orchestrator_skill_present=true

  if (( JSON_OUTPUT == 0 )); then
    echo "Checks"
    echo "------"
  fi

  if ! check_path_exists "agents dir" "${TARGET_AGENTS_DIR}"; then
    failures=$((failures + 1))
  fi
  if ! check_path_exists "skills dir" "${TARGET_SKILLS_DIR}"; then
    failures=$((failures + 1))
  fi
  if ! check_path_exists "orchestrator agent" "${TARGET_AGENTS_DIR}/orchestrator.md"; then
    failures=$((failures + 1))
  fi
  if ! check_path_exists "orchestrator-routing skill" "${TARGET_SKILLS_DIR}/orchestrator-routing/SKILL.md"; then
    failures=$((failures + 1))
  fi

  if check_managed_entrypoint; then
    managed_entrypoint_present=true
  else
    failures=$((failures + 1))
  fi

  if [[ -d "${TARGET_AGENTS_DIR}" ]]; then
    installed_agents="$(find "${TARGET_AGENTS_DIR}" -maxdepth 1 -type f -name '*.md' | wc -l | tr -d ' ')"
    if (( JSON_OUTPUT == 0 )); then
      printf "OK    installed agents count: %s\n" "${installed_agents}"
    fi
  fi

  if [[ -d "${TARGET_SKILLS_DIR}" ]]; then
    installed_skills="$(find "${TARGET_SKILLS_DIR}" -mindepth 1 -maxdepth 1 -type d | wc -l | tr -d ' ')"
    if (( JSON_OUTPUT == 0 )); then
      printf "OK    installed skills count: %s\n" "${installed_skills}"
    fi
  fi

  if (( failures == 0 )); then
    findings+=("Installation looks healthy.")
  else
    findings+=("Found ${failures} failing check(s).")
  fi

  if [[ -f "${TARGET_SKILLS_DIR}/orchestrator-routing/SKILL.md" ]]; then
    findings+=("The orchestrator-routing skill is installed on disk.")
    findings+=("If a current Codex conversation still says the skill is unavailable, the most likely cause is a stale session skill index.")
    warnings=$((warnings + 1))
  fi

  if [[ -f "${TARGET_AGENTS_RULES_FILE}" ]]; then
    findings+=("The managed AGENTS block only sets the default routing preference; it does not force an already-open conversation to refresh its skill list.")
  fi

  if (( failures > 0 )); then
    next_actions+=('Run `bin/codex-agents install` to (re)install the bundle.')
  fi

  if [[ -f "${TARGET_SKILLS_DIR}/orchestrator-routing/SKILL.md" ]]; then
    next_actions+=('Open a new Codex conversation after install/update so the new skill list is picked up.')
    next_actions+=('If a fresh conversation still cannot see the skill, restart the Codex app and run `bin/codex-agents doctor` again.')
  fi

  if (( failures == 0 )); then
    next_actions+=('You can test routing with: 用 orchestrator-routing skill。开发一个实时监控 Codex 配额用量的功能页面。')
  fi

  if (( JSON_OUTPUT == 1 )); then
    python3 - <<'PY' \
      "${TARGET_CODEX_DIR}" \
      "${TARGET_AGENTS_DIR}" \
      "${TARGET_SKILLS_DIR}" \
      "${TARGET_AGENTS_RULES_FILE}" \
      "${agents_dir_present}" \
      "${skills_dir_present}" \
      "${orchestrator_agent_present}" \
      "${orchestrator_skill_present}" \
      "${managed_entrypoint_present}" \
      "${installed_agents}" \
      "${installed_skills}" \
      "${failures}" \
      "${warnings}" \
      "$(printf '%s\n' "${findings[@]}")" \
      "$(printf '%s\n' "${next_actions[@]}")"
import json, sys
codex_home, agents_dir, skills_dir, rules_file, agents_present, skills_present, orchestrator_agent_present, orchestrator_skill_present, managed_present, installed_agents, installed_skills, failures, warnings, findings_blob, next_actions_blob = sys.argv[1:]
def lines(blob):
    return [line for line in blob.splitlines() if line]
payload = {
    "codex_home": codex_home,
    "checks": {
        "agents_dir": {"path": agents_dir, "present": agents_present == "true"},
        "skills_dir": {"path": skills_dir, "present": skills_present == "true"},
        "orchestrator_agent": {"path": f"{agents_dir}/orchestrator.md", "present": orchestrator_agent_present == "true"},
        "orchestrator_routing_skill": {"path": f"{skills_dir}/orchestrator-routing/SKILL.md", "present": orchestrator_skill_present == "true"},
        "managed_entrypoint": {"path": rules_file, "present": managed_present == "true"},
    },
    "installed_agents_count": int(installed_agents),
    "installed_skills_count": int(installed_skills),
    "failures": int(failures),
    "warnings": int(warnings),
    "findings": lines(findings_blob),
    "next_actions": lines(next_actions_blob),
}
print(json.dumps(payload, indent=2, ensure_ascii=False))
PY
  else
    echo
    echo "Findings"
    echo "--------"
    for finding in "${findings[@]}"; do
      echo "- ${finding}"
    done
    echo
    echo "Next actions"
    echo "------------"
    for action in "${next_actions[@]}"; do
      echo "- ${action}"
    done
  fi

  if (( warnings > 0 )); then
    return 0
  fi

  return "${failures}"
}

status_summary() {
  local agents_state="missing"
  local skill_state="missing"
  local managed_state="missing"
  local agent_count=0
  local skill_count=0

  if [[ -d "${TARGET_AGENTS_DIR}" ]]; then
    agents_state="present"
    agent_count="$(find "${TARGET_AGENTS_DIR}" -maxdepth 1 -type f -name '*.md' | wc -l | tr -d ' ')"
  fi

  if [[ -f "${TARGET_SKILLS_DIR}/orchestrator-routing/SKILL.md" ]]; then
    skill_state="present"
  fi

  if [[ -d "${TARGET_SKILLS_DIR}" ]]; then
    skill_count="$(find "${TARGET_SKILLS_DIR}" -mindepth 1 -maxdepth 1 -type d | wc -l | tr -d ' ')"
  fi

  if [[ -f "${TARGET_AGENTS_RULES_FILE}" ]]; then
    local contents
    contents="$(cat "${TARGET_AGENTS_RULES_FILE}")"
    if [[ "${contents}" == *"${ENTRYPOINT_BEGIN}"* && "${contents}" == *"orchestrator-routing"* ]]; then
      managed_state="present"
    fi
  fi

  if (( JSON_OUTPUT == 1 )); then
    python3 - <<'PY' "${TARGET_CODEX_DIR}" "${agents_state}" "${agent_count}" "${skill_state}" "${managed_state}" "${skill_count}"
import json, sys
codex_home, agents_state, agent_count, skill_state, managed_state, skill_count = sys.argv[1:]
payload = {
    "codex_home": codex_home,
    "agents_dir": agents_state,
    "agents_count": int(agent_count),
    "orchestrator_routing_skill": skill_state,
    "managed_entrypoint": managed_state,
    "skills_count": int(skill_count),
}
print(json.dumps(payload, indent=2, ensure_ascii=False))
PY
  else
    echo "codex-agents status"
    echo "agents_dir=${agents_state}"
    echo "agents_count=${agent_count}"
    echo "orchestrator_routing_skill=${skill_state}"
    echo "managed_entrypoint=${managed_state}"
    echo "skills_count=${skill_count}"
  fi
}

version_info() {
  if git -C "${REPO_ROOT}" rev-parse --short HEAD >/dev/null 2>&1; then
    git -C "${REPO_ROOT}" rev-parse --short HEAD
  else
    echo "unknown"
  fi
}

link_cli() {
  local link_path="${LINK_BIN_DIR}/codex-agents"
  mkdir -p "${LINK_BIN_DIR}"
  ln -sfn "${REPO_ROOT}/bin/codex-agents" "${link_path}"
  echo "Linked codex-agents to ${link_path}"
}

unlink_cli() {
  local link_path="${LINK_BIN_DIR}/codex-agents"

  if [[ -L "${link_path}" ]]; then
    rm -f "${link_path}"
    echo "Removed codex-agents link from ${link_path}"
    return 0
  fi

  if [[ -e "${link_path}" ]]; then
    echo "Refusing to remove non-symlink path: ${link_path}" >&2
    exit 1
  fi

  echo "No codex-agents link found at ${link_path}"
}

managed_entrypoint_block() {
  cat <<EOF
${ENTRYPOINT_BEGIN}
## codex-agents Managed Entrypoint

- For non-trivial work that clearly spans multiple phases or roles, use the installed \`orchestrator-routing\` skill before choosing downstream skills or implementation.
- Let \`orchestrator-routing\` classify the task as \`simple\`, \`multi-step\`, or \`complex\`.
- Let \`orchestrator-routing\` prune the smallest useful role chain instead of defaulting to the full role set.
- Let \`orchestrator-routing\` decide whether downstream work should enter skills such as \`brainstorming\`, \`writing-plans\`, or implementation-focused skills.
- Keep \`orchestrator.md\` as the baseline role definition that the routing skill can align to and reference.
- Stronger local project rules and repository-specific rules still override this managed baseline.
${ENTRYPOINT_END}
EOF
}

upsert_managed_entrypoint() {
  mkdir -p "${TARGET_CODEX_DIR}"

  local tmp_file
  tmp_file="$(mktemp)"

  if [[ -f "${TARGET_AGENTS_RULES_FILE}" ]]; then
    awk -v begin="${ENTRYPOINT_BEGIN}" -v end="${ENTRYPOINT_END}" '
      $0 == begin { skip = 1; next }
      $0 == end { skip = 0; next }
      !skip { print }
    ' "${TARGET_AGENTS_RULES_FILE}" > "${tmp_file}"

    if [[ -s "${tmp_file}" ]]; then
      printf "\n\n" >> "${tmp_file}"
    fi
  fi

  managed_entrypoint_block >> "${tmp_file}"
  mv "${tmp_file}" "${TARGET_AGENTS_RULES_FILE}"
}

remove_managed_entrypoint() {
  [[ -f "${TARGET_AGENTS_RULES_FILE}" ]] || return 0

  local tmp_file
  tmp_file="$(mktemp)"

  awk -v begin="${ENTRYPOINT_BEGIN}" -v end="${ENTRYPOINT_END}" '
    $0 == begin { skip = 1; next }
    $0 == end { skip = 0; next }
    !skip { print }
  ' "${TARGET_AGENTS_RULES_FILE}" > "${tmp_file}"

  python3 - <<'PY' "${tmp_file}"
from pathlib import Path
import sys
path = Path(sys.argv[1])
text = path.read_text()
text = text.rstrip() + "\n" if text.strip() else ""
path.write_text(text)
PY

  mv "${tmp_file}" "${TARGET_AGENTS_RULES_FILE}"
}

install_skills() {
  mkdir -p "${TARGET_SKILLS_DIR}"

  local skill_dir
  for skill_dir in "${SOURCE_SKILLS_DIR}"/*; do
    [[ -d "${skill_dir}" ]] || continue
    rm -rf "${TARGET_SKILLS_DIR}/$(basename "${skill_dir}")"
    cp -R "${skill_dir}" "${TARGET_SKILLS_DIR}/"
  done
}

install_agents() {
  mkdir -p "${TARGET_AGENTS_DIR}"
  cp "${SOURCE_AGENTS_DIR}"/*.md "${TARGET_AGENTS_DIR}/"
  install_skills
  upsert_managed_entrypoint
  echo "Installed bundle into ${TARGET_CODEX_DIR}:"
  list_bundle
  echo
  echo "Next actions:"
  echo "- Open a new Codex conversation so the updated skill list is picked up."
  echo "- If a fresh conversation still cannot see orchestrator-routing, restart the Codex app."
}

update_agents() {
  install_agents
}

uninstall_bundle() {
  local agent_file
  for agent_file in "${SOURCE_AGENTS_DIR}"/*.md; do
    [[ -f "${agent_file}" ]] || continue
    rm -f "${TARGET_AGENTS_DIR}/$(basename "${agent_file}")"
  done

  if [[ -d "${TARGET_AGENTS_DIR}" ]] && [[ -z "$(find "${TARGET_AGENTS_DIR}" -maxdepth 1 -type f -name '*.md' -print -quit)" ]]; then
    rmdir "${TARGET_AGENTS_DIR}" 2>/dev/null || true
  fi

  local skill_dir
  for skill_dir in "${SOURCE_SKILLS_DIR}"/*; do
    [[ -d "${skill_dir}" ]] || continue
    rm -rf "${TARGET_SKILLS_DIR}/$(basename "${skill_dir}")"
  done

  remove_managed_entrypoint

  echo "Removed codex-agents managed bundle from ${TARGET_CODEX_DIR}:"
  list_bundle
}

COMMAND="${1:-}"
shift || true
parse_target_flag "$@"
if ((${#REMAINING_ARGS[@]})); then
  set -- "${REMAINING_ARGS[@]}"
else
  set --
fi

case "${COMMAND}" in
  install)
    if [[ $# -gt 0 ]]; then
      echo "install does not accept extra arguments" >&2
      usage
      exit 1
    fi
    install_agents
    ;;
  update)
    if [[ $# -gt 0 ]]; then
      echo "update does not accept extra arguments" >&2
      usage
      exit 1
    fi
    update_agents
    ;;
  doctor)
    if [[ $# -gt 0 ]]; then
      echo "doctor does not accept extra arguments" >&2
      usage
      exit 1
    fi
    doctor
    ;;
  status)
    if [[ $# -gt 0 ]]; then
      echo "status does not accept extra arguments" >&2
      usage
      exit 1
    fi
    status_summary
    ;;
  uninstall)
    if [[ $# -gt 0 ]]; then
      echo "uninstall does not accept extra arguments" >&2
      usage
      exit 1
    fi
    uninstall_bundle
    ;;
  link)
    if [[ $# -gt 0 ]]; then
      echo "link does not accept extra arguments" >&2
      usage
      exit 1
    fi
    link_cli
    ;;
  unlink)
    if [[ $# -gt 0 ]]; then
      echo "unlink does not accept extra arguments" >&2
      usage
      exit 1
    fi
    unlink_cli
    ;;
  version)
    if [[ $# -gt 0 ]]; then
      echo "version does not accept extra arguments" >&2
      usage
      exit 1
    fi
    version_info
    ;;
  list)
    if [[ $# -gt 0 ]]; then
      echo "list does not accept extra arguments" >&2
      usage
      exit 1
    fi
    list_bundle
    ;;
  *)
    usage
    exit 1
    ;;
esac
