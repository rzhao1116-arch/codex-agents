#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
SOURCE_AGENTS_DIR="${REPO_ROOT}/agents"
SOURCE_SKILLS_DIR="${REPO_ROOT}/skills"
TARGET_CODEX_DIR="${HOME}/.codex"
TARGET_AGENTS_DIR=""
TARGET_SKILLS_DIR=""
TARGET_AGENTS_RULES_FILE=""
ENTRYPOINT_BEGIN="<!-- BEGIN CODEX-AGENTS MANAGED ENTRYPOINT -->"
ENTRYPOINT_END="<!-- END CODEX-AGENTS MANAGED ENTRYPOINT -->"

usage() {
  cat <<'EOF'
Usage:
  codex-agents install [--target PATH]   Copy bundled agents and skills into PATH (default: ~/.codex)
  codex-agents update [--target PATH]    Overwrite installed agents and skills from the current repo
  codex-agents status [--target PATH]    Show a lightweight installed-state summary
  codex-agents doctor [--target PATH]    Check installed agents, skills, and managed entrypoint state
  codex-agents uninstall [--target PATH] Remove bundled agents, orchestrator-routing skill, and the managed entrypoint block
  codex-agents list                      List bundled agent files and skills
EOF
}

set_target_paths() {
  TARGET_AGENTS_DIR="${TARGET_CODEX_DIR}/agents"
  TARGET_SKILLS_DIR="${TARGET_CODEX_DIR}/skills"
  TARGET_AGENTS_RULES_FILE="${TARGET_CODEX_DIR}/AGENTS.md"
}

parse_target_flag() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --target)
        [[ $# -ge 2 ]] || {
          echo "Missing value for --target" >&2
          exit 1
        }
        TARGET_CODEX_DIR="$2"
        shift 2
        ;;
      *)
        echo "Unknown argument: $1" >&2
        usage
        exit 1
        ;;
    esac
  done

  set_target_paths
}

list_agents() {
  find "${SOURCE_AGENTS_DIR}" -maxdepth 1 -type f -name '*.md' -print \
    | xargs -I{} basename "{}" \
    | sort
}

list_skills() {
  find "${SOURCE_SKILLS_DIR}" -mindepth 1 -maxdepth 1 -type d -print \
    | xargs -I{} basename "{}" \
    | sort
}

list_bundle() {
  echo "Bundled agents:"
  list_agents
  echo
  echo "Bundled skills:"
  list_skills
}

check_path_exists() {
  local label="$1"
  local path="$2"

  if [[ -e "${path}" ]]; then
    printf "OK    %s: %s\n" "${label}" "${path}"
    return 0
  fi

  printf "FAIL  %s: missing %s\n" "${label}" "${path}"
  return 1
}

check_managed_entrypoint() {
  if [[ ! -f "${TARGET_AGENTS_RULES_FILE}" ]]; then
    printf "FAIL  managed entrypoint: missing %s\n" "${TARGET_AGENTS_RULES_FILE}"
    return 1
  fi

  local contents
  contents="$(cat "${TARGET_AGENTS_RULES_FILE}")"

  if [[ "${contents}" == *"${ENTRYPOINT_BEGIN}"* && "${contents}" == *"${ENTRYPOINT_END}"* ]]; then
    if [[ "${contents}" == *"orchestrator-routing"* ]]; then
      printf "OK    managed entrypoint: orchestrator-routing block present\n"
      return 0
    fi

    printf "WARN  managed entrypoint: managed block present but missing orchestrator-routing language\n"
    return 0
  fi

  printf "FAIL  managed entrypoint: managed block missing from %s\n" "${TARGET_AGENTS_RULES_FILE}"
  return 1
}

doctor() {
  local failures=0
  local warnings=0
  local installed_agents=0
  local installed_skills=0

  echo "Checks"
  echo "------"

  check_path_exists "agents dir" "${TARGET_AGENTS_DIR}" || failures=$((failures + 1))
  check_path_exists "skills dir" "${TARGET_SKILLS_DIR}" || failures=$((failures + 1))
  check_path_exists "orchestrator agent" "${TARGET_AGENTS_DIR}/orchestrator.md" || failures=$((failures + 1))
  check_path_exists "orchestrator-routing skill" "${TARGET_SKILLS_DIR}/orchestrator-routing/SKILL.md" || failures=$((failures + 1))

  if ! check_managed_entrypoint; then
    failures=$((failures + 1))
  fi

  if [[ -d "${TARGET_AGENTS_DIR}" ]]; then
    installed_agents="$(find "${TARGET_AGENTS_DIR}" -maxdepth 1 -type f -name '*.md' | wc -l | tr -d ' ')"
    printf "OK    installed agents count: %s\n" "${installed_agents}"
  fi

  if [[ -d "${TARGET_SKILLS_DIR}" ]]; then
    installed_skills="$(find "${TARGET_SKILLS_DIR}" -mindepth 1 -maxdepth 1 -type d | wc -l | tr -d ' ')"
    printf "OK    installed skills count: %s\n" "${installed_skills}"
  fi

  echo
  echo "Findings"
  echo "--------"

  if (( failures == 0 )); then
    echo "- Installation looks healthy."
  else
    echo "- Found ${failures} failing check(s)."
  fi

  if [[ -f "${TARGET_SKILLS_DIR}/orchestrator-routing/SKILL.md" ]]; then
    echo "- The orchestrator-routing skill is installed on disk."
    echo "- If a current Codex conversation still says the skill is unavailable, the most likely cause is a stale session skill index."
    warnings=$((warnings + 1))
  fi

  if [[ -f "${TARGET_AGENTS_RULES_FILE}" ]]; then
    echo "- The managed AGENTS block only sets the default routing preference; it does not force an already-open conversation to refresh its skill list."
  fi

  echo
  echo "Next actions"
  echo "------------"

  if (( failures > 0 )); then
    echo "- Run \`bin/codex-agents install\` to (re)install the bundle."
  fi

  if [[ -f "${TARGET_SKILLS_DIR}/orchestrator-routing/SKILL.md" ]]; then
    echo "- Open a new Codex conversation after install/update so the new skill list is picked up."
    echo "- If a fresh conversation still cannot see the skill, restart the Codex app and run \`bin/codex-agents doctor\` again."
  fi

  if (( failures == 0 )); then
    echo "- You can test routing with: 用 orchestrator-routing skill。开发一个实时监控 Codex 配额用量的功能页面。"
  fi

  if (( warnings > 0 )); then
    return 0
  fi

  return "${failures}"
}

status_summary() {
  local agents_state="missing"
  local skill_state="missing"
  local managed_state="missing"
  local agent_count=0
  local skill_count=0

  if [[ -d "${TARGET_AGENTS_DIR}" ]]; then
    agents_state="present"
    agent_count="$(find "${TARGET_AGENTS_DIR}" -maxdepth 1 -type f -name '*.md' | wc -l | tr -d ' ')"
  fi

  if [[ -f "${TARGET_SKILLS_DIR}/orchestrator-routing/SKILL.md" ]]; then
    skill_state="present"
  fi

  if [[ -d "${TARGET_SKILLS_DIR}" ]]; then
    skill_count="$(find "${TARGET_SKILLS_DIR}" -mindepth 1 -maxdepth 1 -type d | wc -l | tr -d ' ')"
  fi

  if [[ -f "${TARGET_AGENTS_RULES_FILE}" ]]; then
    local contents
    contents="$(cat "${TARGET_AGENTS_RULES_FILE}")"
    if [[ "${contents}" == *"${ENTRYPOINT_BEGIN}"* && "${contents}" == *"orchestrator-routing"* ]]; then
      managed_state="present"
    fi
  fi

  echo "codex-agents status"
  echo "agents_dir=${agents_state}"
  echo "agents_count=${agent_count}"
  echo "orchestrator_routing_skill=${skill_state}"
  echo "managed_entrypoint=${managed_state}"
  echo "skills_count=${skill_count}"
}

managed_entrypoint_block() {
  cat <<EOF
${ENTRYPOINT_BEGIN}
## codex-agents Managed Entrypoint

- For non-trivial work that clearly spans multiple phases or roles, use the installed \`orchestrator-routing\` skill before choosing downstream skills or implementation.
- Let \`orchestrator-routing\` classify the task as \`simple\`, \`multi-step\`, or \`complex\`.
- Let \`orchestrator-routing\` prune the smallest useful role chain instead of defaulting to the full role set.
- Let \`orchestrator-routing\` decide whether downstream work should enter skills such as \`brainstorming\`, \`writing-plans\`, or implementation-focused skills.
- Keep \`orchestrator.md\` as the baseline role definition that the routing skill can align to and reference.
- Stronger local project rules and repository-specific rules still override this managed baseline.
${ENTRYPOINT_END}
EOF
}

upsert_managed_entrypoint() {
  mkdir -p "${TARGET_CODEX_DIR}"

  local tmp_file
  tmp_file="$(mktemp)"

  if [[ -f "${TARGET_AGENTS_RULES_FILE}" ]]; then
    awk -v begin="${ENTRYPOINT_BEGIN}" -v end="${ENTRYPOINT_END}" '
      $0 == begin { skip = 1; next }
      $0 == end { skip = 0; next }
      !skip { print }
    ' "${TARGET_AGENTS_RULES_FILE}" > "${tmp_file}"

    if [[ -s "${tmp_file}" ]]; then
      printf "\n\n" >> "${tmp_file}"
    fi
  fi

  managed_entrypoint_block >> "${tmp_file}"
  mv "${tmp_file}" "${TARGET_AGENTS_RULES_FILE}"
}

remove_managed_entrypoint() {
  [[ -f "${TARGET_AGENTS_RULES_FILE}" ]] || return 0

  local tmp_file
  tmp_file="$(mktemp)"

  awk -v begin="${ENTRYPOINT_BEGIN}" -v end="${ENTRYPOINT_END}" '
    $0 == begin { skip = 1; next }
    $0 == end { skip = 0; next }
    !skip { print }
  ' "${TARGET_AGENTS_RULES_FILE}" > "${tmp_file}"

  python3 - <<'PY' "${tmp_file}"
from pathlib import Path
import sys
path = Path(sys.argv[1])
text = path.read_text()
text = text.rstrip() + "\n" if text.strip() else ""
path.write_text(text)
PY

  mv "${tmp_file}" "${TARGET_AGENTS_RULES_FILE}"
}

install_skills() {
  mkdir -p "${TARGET_SKILLS_DIR}"

  local skill_dir
  for skill_dir in "${SOURCE_SKILLS_DIR}"/*; do
    [[ -d "${skill_dir}" ]] || continue
    rm -rf "${TARGET_SKILLS_DIR}/$(basename "${skill_dir}")"
    cp -R "${skill_dir}" "${TARGET_SKILLS_DIR}/"
  done
}

install_agents() {
  mkdir -p "${TARGET_AGENTS_DIR}"
  cp "${SOURCE_AGENTS_DIR}"/*.md "${TARGET_AGENTS_DIR}/"
  install_skills
  upsert_managed_entrypoint
  echo "Installed bundle into ${TARGET_CODEX_DIR}:"
  list_bundle
  echo
  echo "Next actions:"
  echo "- Open a new Codex conversation so the updated skill list is picked up."
  echo "- If a fresh conversation still cannot see orchestrator-routing, restart the Codex app."
}

update_agents() {
  install_agents
}

uninstall_bundle() {
  local agent_file
  for agent_file in "${SOURCE_AGENTS_DIR}"/*.md; do
    [[ -f "${agent_file}" ]] || continue
    rm -f "${TARGET_AGENTS_DIR}/$(basename "${agent_file}")"
  done

  if [[ -d "${TARGET_AGENTS_DIR}" ]] && [[ -z "$(find "${TARGET_AGENTS_DIR}" -maxdepth 1 -type f -name '*.md' -print -quit)" ]]; then
    rmdir "${TARGET_AGENTS_DIR}" 2>/dev/null || true
  fi

  local skill_dir
  for skill_dir in "${SOURCE_SKILLS_DIR}"/*; do
    [[ -d "${skill_dir}" ]] || continue
    rm -rf "${TARGET_SKILLS_DIR}/$(basename "${skill_dir}")"
  done

  remove_managed_entrypoint

  echo "Removed codex-agents managed bundle from ${TARGET_CODEX_DIR}:"
  list_bundle
}

COMMAND="${1:-}"
shift || true
parse_target_flag "$@"

case "${COMMAND}" in
  install)
    install_agents
    ;;
  update)
    update_agents
    ;;
  doctor)
    doctor
    ;;
  status)
    status_summary
    ;;
  uninstall)
    uninstall_bundle
    ;;
  list)
    if [[ $# -gt 0 ]]; then
      echo "list does not accept extra arguments" >&2
      usage
      exit 1
    fi
    list_bundle
    ;;
  *)
    usage
    exit 1
    ;;
esac
